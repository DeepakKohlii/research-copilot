# Copy to .env. With LLM_PROVIDER=auto (default), only set the block you need.

ENVIRONMENT=development
DATABASE_URL=sqlite:///./copilot.db

# Remote: set OPENAI_API_KEY (OpenRouter/Groq/OpenAI — URL inferred from key prefix)
# OPENAI_API_KEY=sk-or-...

# Local Ollama: only base URL + model, no key required
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# Anthropic: only the key (+ optional model)
# ANTHROPIC_API_KEY=sk-ant-...

# Force offline mock mode
# LLM_PROVIDER=mock

# Search: auto (default) uses Tavily when TAVILY_API_KEY is set, else mock
SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-...
QUALITY_THRESHOLD=0.7
MAX_RESEARCH_PASSES=2
LOG_LEVEL=INFO
